# ============================================
# Nginx 配置示例 — 公网域名 + HTTPS + SPA + API 反代
# 使用方法：
#   1. 将 your-domain.com 替换为你的域名
#   2. npm run build 后将 dist/ 上传到 /var/www/ljl-blog-web
#   3. 配置 SSL 证书（Let's Encrypt / 云厂商）
#   4. sudo ln -s .../deploy/nginx.conf.example /etc/nginx/sites-enabled/ljl-blog
#   5. sudo nginx -t && sudo systemctl reload nginx
# ============================================

server {
    listen 80;
    server_name your-domain.com www.your-domain.com;

    # HTTP 重定向到 HTTPS
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name your-domain.com www.your-domain.com;

    # SSL 证书路径（按实际修改）
    ssl_certificate     /etc/nginx/ssl/your-domain.com.pem;
    ssl_certificate_key /etc/nginx/ssl/your-domain.com.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    # 前端静态资源
    root /var/www/ljl-blog-web;
    index index.html;

    # Gzip
    gzip on;
    gzip_types text/plain text/css application/json application/javascript text/xml application/xml;
    gzip_min_length 1024;

    # 安全头
    add_header X-Frame-Options SAMEORIGIN;
    add_header X-Content-Type-Options nosniff;
    add_header Referrer-Policy strict-origin-when-cross-origin;

    # Spring Boot API 反代（同域 /api，避免跨域）
    location /api/ {
        proxy_pass http://127.0.0.1:8080/api/;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # SPA 路由 — 所有非文件请求回退 index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # 静态资源长缓存
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?)$ {
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}
