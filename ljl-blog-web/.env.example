# ============================================
# 环境变量模板 — 复制为 .env.local 或 .env.production.local 后修改
# ============================================

# 站点公网地址（绑定域名后填写）
VITE_SITE_URL=https://your-domain.com

# 站点信息
VITE_SITE_NAME=LJL Knowledge Hub
VITE_SITE_DESCRIPTION=个人知识库 · 学习笔记 · 项目沉淀 · 旅行记录

# 后端 API（同域反代填 /api，独立域名填完整 URL）
VITE_API_BASE_URL=/api

# Mock 开关：true=JSON Mock，false=请求 Spring Boot
VITE_USE_MOCK=false

# 子路径部署（根目录留空或 /）
VITE_BASE_PATH=/

# 开发环境专用 — 本地 Spring Boot 代理目标（对接后端时取消注释）
# VITE_API_PROXY_TARGET=http://localhost:8080
