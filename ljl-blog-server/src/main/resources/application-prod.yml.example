# 生产环境配置示例 — 复制为 application-local.yml 或在服务器上单独维护
# 本地开发请勿覆盖已有的 application-local.yml

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/ljl_blog?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai
    username: ljl_blog
    password: CHANGE_ME
    driver-class-name: com.mysql.cj.jdbc.Driver

app:
  jwt:
    secret: CHANGE-ME-TO-A-RANDOM-STRING-AT-LEAST-32-CHARS
    expiration-ms: 28800000
  admin:
    username: admin
    password: CHANGE_ME
  storage:
    root: /opt/ljl-blog/data
    content-dir: content/blog
    upload-dir: uploads/images
    public-url-prefix: /uploads
